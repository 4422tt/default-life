# Public URL of the separately deployed Vercel recognition function.
# This value is safe to expose; it is an endpoint, not an OpenAI secret.
NEXT_PUBLIC_ORDER_RECOGNITION_ENDPOINT=https://YOUR-VERCEL-PROJECT.vercel.app/api/recognize-order

# Set OPENAI_API_KEY only in Vercel's Environment Variables for vercel-api.
# Never add OPENAI_API_KEY to this file, GitHub Pages, or a NEXT_PUBLIC_ variable.

# Optional, server-side Vercel variables:
# OPENAI_VISION_MODEL=gpt-4o-mini
# ALLOWED_ORIGINS=https://4422tt.github.io
