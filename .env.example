# Public URL of the Vercel screenshot-recognition function.
# This is safe to expose because it is only an endpoint, not a provider secret.
NEXT_PUBLIC_ORDER_RECOGNITION_ENDPOINT=https://YOUR-VERCEL-PROJECT.vercel.app/api/orders/recognize

# Set provider keys only in Vercel's Environment Variables.
# Never add them to this file, GitHub Pages, or a NEXT_PUBLIC_ variable.
# DASHSCOPE_API_KEY=your-model-studio-api-key

# Optional, server-side Vercel variables:
# DASHSCOPE_VISION_MODEL=qwen3.6-flash
# Optional China (Beijing) compatible endpoint. Set this only if your Model Studio
# console provides a workspace-specific endpoint.
# DASHSCOPE_BASE_URL=https://YOUR-WORKSPACE.cn-beijing.maas.aliyuncs.com/compatible-mode/v1/chat/completions
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_MODEL=deepseek-chat
# ALLOWED_ORIGINS=https://4422tt.github.io
