# Public URL of the separately deployed Vercel life-rule function.
# This value is safe to expose; it is an endpoint, not a provider secret.
NEXT_PUBLIC_ORDER_RECOGNITION_ENDPOINT=https://YOUR-VERCEL-PROJECT.vercel.app/api/recognize-order

# Set DEEPSEEK_API_KEY only in Vercel's Environment Variables for vercel-api.
# Never add DEEPSEEK_API_KEY to this file, GitHub Pages, or a NEXT_PUBLIC_ variable.

# Optional, server-side Vercel variables:
# DEEPSEEK_MODEL=deepseek-chat
# ALLOWED_ORIGINS=https://4422tt.github.io
